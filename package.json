{
  "name": "fifa-conquest",
  "version": "1.0.0",
  "description": "FIFA Conquest - Territory conquest game",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable"
  },
  "build": {
    "appId": "com.fifaconquest.game",
    "productName": "FIFA Conquest",
    "files": [
      "electron/**/*",
      "index.html",
      "styles/**/*",
      "assets/**/*",
      "js/**/*",
      "lang/**/*",
      "data/**/*",
      "desafios/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icons/favicon.ico"
    }
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  }
}
